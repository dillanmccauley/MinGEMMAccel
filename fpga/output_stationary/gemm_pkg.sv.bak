// gemm_pkg.sv
// Shared parameters, types, and utility functions for the im2col GEMM pipeline.
//
// Convolution notation used throughout:
//   N  ? batch size (processed one image at a time in this design)
//   C  ? input channels
//   H,W ? input height / width
//   K  ? number of output filters
//   kH,kW ? kernel height / width
//   S  ? stride (assumed square)
//   P  ? zero-padding (assumed symmetric, square)
//   OH = (H + 2P - kH) / S + 1
//   OW = (W + 2P - kW) / S + 1
//
// im2col matrix shapes (column-major GEMM convention):
//   Matrix A (activation columns): rows = kH*kW*C,  cols = OH*OW
//   Matrix B (weight rows)       : rows = K,         cols = kH*kW*C
//   Output                       : rows = K,          cols = OH*OW
//
// Data format: signed 2's-complement integers throughout.
// Activation width and accumulator width are parameterised.

`ifndef IM2COL_PKG_SV
`define IM2COL_PKG_SV

package gemm_pkg;

  // -----------------------------------------------------------------------
  // Convolution hyper-parameters (override via parameter override or localparams
  // in the instantiating module for different network layers).
  // -----------------------------------------------------------------------
  parameter int IMG_H   = 28;   // Input image height
  parameter int IMG_W   = 28;   // Input image width
  parameter int IMG_C   = 1;    // Input channels
  parameter int KH      = 3;    // Kernel height
  parameter int KW      = 3;    // Kernel width
  parameter int K_FILT  = 32;   // Number of filters (output channels)
  parameter int STRIDE  = 1;    // Convolution stride
  parameter int PAD     = 1;    // Zero-padding (same-padding for stride=1: P=(K-1)/2)

  // -----------------------------------------------------------------------
  // Derived geometry ? computed at elaboration time, never override directly.
  // -----------------------------------------------------------------------
  parameter int OH = (IMG_H + 2*PAD - KH) / STRIDE + 1;  // Output height
  parameter int OW = (IMG_W + 2*PAD - KW) / STRIDE + 1;  // Output width

  parameter int COL_ROWS  = KH * KW * IMG_C;   // Rows of the im2col matrix A
  parameter int COL_COLS  = OH * OW;            // Columns of the im2col matrix A

  // -----------------------------------------------------------------------
  // Data widths
  // -----------------------------------------------------------------------
  parameter int ACT_W   = 8;    // Activation / input data width (signed)
  parameter int WGT_W   = 8;    // Weight data width (signed)
  parameter int ACC_W   = 32;   // Accumulator width (must hold worst-case sum)
  parameter int OUT_W   = 16;   // Output data width after optional requantisation

  // -----------------------------------------------------------------------
  // Address widths (derived ? wide enough for the largest memory)
  // -----------------------------------------------------------------------
  parameter int IMG_DEPTH  = IMG_C * IMG_H * IMG_W;
  parameter int COL_DEPTH  = COL_ROWS * COL_COLS;
  parameter int WGT_DEPTH  = K_FILT  * COL_ROWS;
  parameter int OUT_DEPTH  = K_FILT  * OH * OW;

  parameter int IMG_ABITS  = $clog2(IMG_DEPTH + 1);
  parameter int COL_ABITS  = $clog2(COL_DEPTH + 1);
  parameter int WGT_ABITS  = $clog2(WGT_DEPTH + 1);
  parameter int OUT_ABITS  = $clog2(OUT_DEPTH + 1);

  // -----------------------------------------------------------------------
  // Convenience types
  // -----------------------------------------------------------------------
  typedef logic signed [ACT_W-1:0]   act_t;
  typedef logic signed [WGT_W-1:0]   wgt_t;
  typedef logic signed [ACC_W-1:0]   acc_t;
  typedef logic signed [OUT_W-1:0]   out_t;

  // Pixel address within flat CHW image tensor: (c*H + h)*W + w
  function automatic logic [IMG_ABITS-1:0] pixel_addr(
    input int c, h, w
  );
    return (c * IMG_H + h) * IMG_W + w;
  endfunction

endpackage : gemm_pkg

`endif // GEMM_PKG