// =============================================================================
// pe_output_stationary.sv  ?  final corrected
//
// Fix: c_out on drain must chain c_in so partial sums accumulate downward.
//   Old: c_out <= c_accum + a*b          (ignores c_in ? only last PE visible)
//   New: c_out <= c_in + c_accum + a*b   (chains all PEs into c_wire[ROWS])
// =============================================================================
module pe_output_stationary #(
    parameter DATA_WIDTH  = 8,
    parameter ACCUM_WIDTH = 32
)(
    input  logic                   clk,
    input  logic                   rst,
    input  logic                   en,
    input  logic                   drain,
    input  logic [DATA_WIDTH-1:0]  a_in,
    input  logic [DATA_WIDTH-1:0]  b_in,
    input  logic [ACCUM_WIDTH-1:0] c_in,
    output logic [DATA_WIDTH-1:0]  a_out,
    output logic [DATA_WIDTH-1:0]  b_out,
    output logic [ACCUM_WIDTH-1:0] c_out
);
    logic [ACCUM_WIDTH-1:0] c_accum;
    logic [ACCUM_WIDTH-1:0] product;
    assign product = ((a_in == '0) || (b_in == '0))
                     ? '0 : ACCUM_WIDTH'(a_in) * ACCUM_WIDTH'(b_in);
 
    always_ff @(posedge clk) begin
        if (rst) begin
            a_out <= '0; b_out <= '0; c_out <= '0; c_accum <= '0;
        end else if (en) begin
            a_out <= a_in;
            b_out <= b_in;
            if (drain) begin
                // Chain c_in so all PE accumulators sum into c_wire[ROWS]
                c_out   <= c_in + c_accum + product;
                c_accum <= '0;
            end else begin
                c_accum <= c_accum + product;
                c_out   <= c_in;    // relay c_in downward during accumulation
            end
        end
    end
endmodule