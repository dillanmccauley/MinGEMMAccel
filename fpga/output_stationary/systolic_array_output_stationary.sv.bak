// =============================================================================
// systolic_array_output_stationary.sv  ?  final corrected
//
// Architecture: MODE A ? parallel input.
//   All ROWS PE rows receive their own b_in simultaneously.
//   b_wire[i][0] = b_in[i] for i=0..ROWS-1  (row dimension, not column).
//
// Bug history:
//   Original:  assign b_wire[0][i] = b_in[i]  ? indexed COLUMN dim (b_wire[row=0][col=i])
//              valid only for i=0 with COLS=1; b_in[1..8] unconnected.
//   First fix: assign b_wire[0][0] = b_in[0] only ? correct wiring but converted
//              to MODE B (serial pipeline) which gives wrong accumulation.
//   Final fix: assign b_wire[i][0] = b_in[i]  ? indexes ROW dim correctly.
//              All 9 b_in ports reach their PE rows directly.
// =============================================================================
module systolic_array_output_stationary #(
    parameter DATA_WIDTH  = 8,
    parameter ACCUM_WIDTH = 32,
    parameter ROWS        = 9,
    parameter COLS        = 1
)(
    input  logic clk,
    input  logic rst,
    input  logic en,
    input  logic drain,
    // a_in[k]: weight for PE row k  (constant across all passes for K=1)
    // b_in[k]: activation for PE row k  (parallel, all driven simultaneously)
    input  logic [DATA_WIDTH-1:0]  a_in [ROWS-1:0],
    input  logic [DATA_WIDTH-1:0]  b_in [ROWS-1:0],
    output logic [ACCUM_WIDTH-1:0] c_out [COLS-1:0]
);
    logic [DATA_WIDTH-1:0]  a_wire [ROWS-1:0][COLS:0];
    logic [DATA_WIDTH-1:0]  b_wire [ROWS:0][COLS-1:0];
    logic [ACCUM_WIDTH-1:0] c_wire [ROWS:0][COLS-1:0];
 
    genvar i, j;
 
    // c_out reads from bottom of column; c_wire[0] tied to zero
    generate
        for (i = 0; i < COLS; i++) begin : assign_cols
            assign c_out[i]     = c_wire[ROWS][i];
            assign c_wire[0][i] = '0;
        end
    endgenerate
 
    // Each PE row gets its own independent a and b inputs.
    // FIX: b_wire[i][0] ? first dimension is ROW (0..ROWS), second is COL (0..COLS-1).
    //      With COLS=1, valid indices are b_wire[0..9][0].
    //      b_wire[i][0] = b_in[i] connects activation i directly to PE row i.
    generate
        for (i = 0; i < ROWS; i++) begin : assign_rows
            assign a_wire[i][0] = a_in[i];
            assign b_wire[i][0] = b_in[i];   // FIX: row index, not column index
        end
    endgenerate
 
    // PE grid
    generate
        for (i = 0; i < ROWS; i++) begin : row
            for (j = 0; j < COLS; j++) begin : col
                pe_output_stationary #(
                    .DATA_WIDTH  (DATA_WIDTH),
                    .ACCUM_WIDTH (ACCUM_WIDTH)
                ) pe_inst (
                    .clk   (clk), .rst (rst), .en (en), .drain (drain),
                    .a_in  (a_wire[i][j]),   .b_in  (b_wire[i][j]),
                    .c_in  (c_wire[i][j]),   .a_out (a_wire[i][j+1]),
                    .b_out (b_wire[i+1][j]), .c_out (c_wire[i+1][j])
                );
            end
        end
    endgenerate
endmodule
