`timescale 1ns/1ps
`include "gemm_pkg.sv"

// =============================================================================
// tb_1x9_conv  ?  final
//
// Matches the final corrected DUT with:
//   - Parallel b_in (all ROWS driven simultaneously in 1 cycle)
//   - Combinational c_out on drain (sum valid at negedge AFTER drain posedge)
//   - drain_r delayed clear (c_accum valid throughout drain cycle)
//
// Per-pass timing (3 clock cycles):
//
//   Cycle 1 ? MAC:
//     Drive a_in[k]=kernel[k], b_in[k]=col_buf[k], drain=0.
//     Posedge: c_accum[k] = kernel[k] * col_buf[k]  for all k.
//
//   Cycle 2 ? Drain:
//     Assert drain=1, clear a_in/b_in to 0.
//     Posedge: drain_r<=1; c_accum unchanged (drain_r was 0, no clear fires).
//     Negedge (SAMPLE HERE): drain=1, c_accum=A[k] ? c_out combinationally
//       = c_wire[ROWS] = sum of all A[k] = dot product.
//     Set drain=0.
//
//   Cycle 3 ? Clear:
//     Posedge: drain_r=1 AND drain=0 ? c_accum<=0 for all PEs.
//     Array is clean for next pass.
//
// Total: 3 cycles × 9 passes = 27 cycles for full 3×3 convolution.
// =============================================================================

module tb_1x9_conv;
    import gemm_pkg::*;

    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------
    parameter DATA_WIDTH  = 8;
    parameter ACCUM_WIDTH = 32;
    parameter PE_ROWS     = 9;
    parameter PE_COLS     = 1;

    parameter H   = 3, W   = 3;
    parameter KH  = 3, KW  = 3;
    parameter S   = 1, PAD = 1;
    parameter OH  = 3, OW  = 3;
    parameter COL_ROWS = KH * KW;   // 9
    parameter COL_COLS = OH * OW;   // 9

    // -------------------------------------------------------------------------
    // DUT ports
    // -------------------------------------------------------------------------
    logic clk, rst, en, drain;
    logic [DATA_WIDTH-1:0]  a_in  [PE_ROWS-1:0];
    logic [DATA_WIDTH-1:0]  b_in  [PE_ROWS-1:0];
    logic [ACCUM_WIDTH-1:0] c_out [PE_COLS-1:0];

    // -------------------------------------------------------------------------
    // addr gen ports
    // -------------------------------------------------------------------------
    logic [$clog2(COL_COLS)-1:0] ag_col_idx;
    logic [$clog2(COL_ROWS)-1:0] ag_row_idx;
    logic [IMG_ABITS-1:0]        ag_img_addr;
    logic                        ag_pad_pixel;

    // -------------------------------------------------------------------------
    // Instantiations
    // -------------------------------------------------------------------------
    systolic_array_output_stationary #(
        .DATA_WIDTH  (DATA_WIDTH),
        .ACCUM_WIDTH (ACCUM_WIDTH),
        .ROWS        (PE_ROWS),
        .COLS        (PE_COLS)
    ) dut (
        .clk   (clk), .rst (rst), .en (en), .drain (drain),
        .a_in  (a_in), .b_in (b_in), .c_out (c_out)
    );

    im2col_addr_gen addr_gen (
        .col_idx   (ag_col_idx), .row_idx   (ag_row_idx),
        .img_addr  (ag_img_addr), .pad_pixel (ag_pad_pixel)
    );

    // -------------------------------------------------------------------------
    // Clock
    // -------------------------------------------------------------------------
    initial clk = 0;
    always  #5 clk = ~clk;

    // -------------------------------------------------------------------------
    // Memories
    // -------------------------------------------------------------------------
    logic [DATA_WIDTH-1:0]  image_sram [0:8];
    logic [DATA_WIDTH-1:0]  kernel     [0:COL_ROWS-1];
    logic [DATA_WIDTH-1:0]  col_buf    [0:COL_ROWS-1];

    logic [ACCUM_WIDTH-1:0] expected [0:8] = '{
        32'd26,  32'd56,  32'd54,
        32'd84,  32'd165, 32'd144,
        32'd134, 32'd236, 32'd186
    };

    int errors = 0;

    // -------------------------------------------------------------------------
    // Task: gather one im2col column (combinational addr gen, no clock consumed)
    // -------------------------------------------------------------------------
    task automatic gather_column(input int ci);
        $display("  [gather] col_idx=%0d (oh=%0d, ow=%0d)",
                  ci, ci/OW, ci%OW);
        for (int ri = 0; ri < COL_ROWS; ri++) begin
            ag_col_idx = ci[($clog2(COL_COLS)-1):0];
            ag_row_idx = ri[($clog2(COL_ROWS)-1):0];
            #1;   // combinational settle ? not a clock edge
            col_buf[ri] = ag_pad_pixel ? '0 : image_sram[ag_img_addr];
            $display("    row_idx=%0d | pad=%0b addr=%0d val=%0d",
                      ri, ag_pad_pixel, ag_img_addr, col_buf[ri]);
        end
    endtask

    // -------------------------------------------------------------------------
    // Task: stream one column through the array and verify
    //
    // Cycle 1 ? MAC:
    //   a_in[k] = kernel[k]   (weight for PE row k)
    //   b_in[k] = col_buf[k]  (activation for PE row k ? parallel, same cycle)
    //   @(negedge clk) ? posedge: c_accum[k] = kernel[k]*col_buf[k]
    //
    // Cycle 2 ? Drain:
    //   drain=1, a_in/b_in=0
    //   @(negedge clk) ? posedge: drain_r<=1, c_accum unchanged
    //   AT negedge: c_out = c_in + c_accum = combinational chain sum ? SAMPLE
    //   drain=0
    //
    // Cycle 3 ? Clear:
    //   @(negedge clk) ? posedge: drain_r=1, drain=0 ? c_accum<=0
    // -------------------------------------------------------------------------
    task automatic stream_and_verify(input int ci);
        automatic logic [ACCUM_WIDTH-1:0] got;

        $display("  [stream] col_idx=%0d", ci);

        // ?? Cycle 1: MAC ??
        for (int k = 0; k < PE_ROWS; k++) begin
            a_in[k] = kernel[k];
            b_in[k] = col_buf[k];
        end
        drain = 0;
        @(negedge clk);   // posedge: c_accum[k] = kernel[k]*col_buf[k]

        // ?? Cycle 2: Drain ??
        // Assert drain; zero a/b to prevent any extra MAC on drain posedge.
        // After drain posedge, drain_r=1 but c_accum is still A[k] (no clear yet).
        // At the negedge after drain posedge, drain=1 and c_accum=A[k]:
        //   c_out = c_wire[9] = sum(A[k]) combinationally.
        drain = 1;
        for (int k = 0; k < PE_ROWS; k++) begin
            a_in[k] = '0;
            b_in[k] = '0;
        end
        @(negedge clk);   // posedge: drain_r<=1; c_accum unchanged; negedge: c_out valid

        got = c_out[0];   // sample combinational c_wire[ROWS] ? valid here
        $display("  [drain]  c_out[0] = %0d", got);
        drain = 0;

        // ?? Cycle 3: Clear ??
        // Let drain_r fire and zero c_accum before next pass.
        @(negedge clk);   // posedge: drain_r=1 AND drain=0 ? c_accum<=0

        // ?? Verify ??
        if (got !== expected[ci]) begin
            $display("  FAIL pass=%0d (oh=%0d ow=%0d): expected=%0d got=%0d",
                      ci, ci/OW, ci%OW, expected[ci], got);
            errors++;
        end else begin
            $display("  PASS pass=%0d (oh=%0d ow=%0d): got=%0d",
                      ci, ci/OW, ci%OW, got);
        end
    endtask

    // -------------------------------------------------------------------------
    // Main stimulus
    // -------------------------------------------------------------------------
    initial begin
        image_sram = '{ 8'd1, 8'd2, 8'd3,
                        8'd4, 8'd5, 8'd6,
                        8'd7, 8'd8, 8'd9 };

        kernel = '{ 8'd9, 8'd8, 8'd7,
                    8'd6, 8'd5, 8'd4,
                    8'd3, 8'd2, 8'd1 };

        rst = 1; en = 0; drain = 0;
        for (int k = 0; k < PE_ROWS; k++) begin
            a_in[k] = '0; b_in[k] = '0;
        end
        repeat(4) @(negedge clk);
        rst = 0;
        repeat(2) @(negedge clk);
        en = 1;

        $display("=== 1x9 systolic array ? 3x3 conv C=1 K=1 S=1 P=1 ===");
        $display("Parallel input: all 9 b_in driven simultaneously");
        $display("c_out: combinational on drain ? chain sum valid at negedge");
        $display("Cycles per pass: 1 MAC + 1 drain + 1 clear = 3");
        $display("");

        for (int ci = 0; ci < COL_COLS; ci++) begin
            $display("--- Pass %0d / %0d ---", ci, COL_COLS-1);
            gather_column(ci);
            stream_and_verify(ci);
            $display("");
        end

        $display("=== Done. Errors: %0d / %0d ===", errors, COL_COLS);
        $finish;
    end

endmodule